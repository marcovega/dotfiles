# Copy this file to .env.git and fill in your details
# This file will be used to generate your .gitconfig

# Your full name for git commits
GIT_NAME="Your Full Name"

# Your email for git commits  
GIT_EMAIL="your.email@example.com"

# Your GPG signing key (optional - remove gpgsign = true from template if not using)
GIT_SIGNING_KEY="YOUR_GPG_KEY_ID"
